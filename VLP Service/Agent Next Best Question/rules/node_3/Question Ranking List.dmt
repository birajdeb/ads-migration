<?xml version="1.0" encoding="UTF-8"?>
<ilog.rules.studio.model.dt:DecisionTable xmi:version="2.0" xmlns:xmi="http://www.omg.org/XMI" xmlns:ilog.rules.studio.model.dt="http://ilog.rules.studio/model/dt.ecore">
  <name>Question Ranking List</name>
  <uuid>1acde547-f74b-4fa8-bbd7-f516eea8c141</uuid>
  <locale>en_US</locale>
  <definition><DT xmlns="http://schemas.ilog.com/Rules/7.0/DecisionTable" Version="7.0">
    <Body>
        <Properties>
            <Property Name="UI.MediaType"><![CDATA[Web]]></Property>
            <Property Name="UI.RenderBoolean" Type="xs:boolean"><![CDATA[true]]></Property>
        </Properties>
        <Preconditions>
            <Text><![CDATA[definitions
set 'a Agent Decline Ranking' to an Agent Ranking in 'Agent Decline Ranking';
set 'a Agent Abondonment Ranking' to an Agent Ranking in 'Agent Abandonment Ranking';]]></Text>
        </Preconditions>
        <Structure>
            <ConditionDefinitions>
                <ConditionDefinition Id="C0">
                    <ExpressionDefinition>
                        <Text><![CDATA[the Question ID of 'a Agent Decline Ranking' is <a Questions> ]]></Text>
                    </ExpressionDefinition>
                </ConditionDefinition>
                <ConditionDefinition Id="C1">
                    <ExpressionDefinition>
                        <Text><![CDATA[the Factored Rank of 'a Agent Decline Ranking' is <a number> ]]></Text>
                    </ExpressionDefinition>
                </ConditionDefinition>
            </ConditionDefinitions>
            <ActionDefinitions>
                <ActionDefinition Id="A0">
                    <ExpressionDefinition>
                        <Text><![CDATA[add a new Question Ranking  where
	the Question ID is <Question ID> , 
	the Rank is <Rank> to decision]]></Text>
                    </ExpressionDefinition>
                </ActionDefinition>
            </ActionDefinitions>
        </Structure>
        <Contents>
            <Partition DefId="C0">
                <Condition>
                    <Expression>
                        <Param><![CDATA[the Question ID of 'a Agent Abondonment Ranking']]></Param>
                    </Expression>
                    <Partition DefId="C1">
                        <Condition>
                            <Expression>
                                <Text><![CDATA[<a number> is at least <a number>]]></Text>
                                <Param><![CDATA[the Factored Rank of 'a Agent Abondonment Ranking']]></Param>
                            </Expression>
                            <ActionSet>
                                <Action DefId="A0">
                                    <Expression>
                                        <Param><![CDATA[the Question ID of 'a Agent Decline Ranking']]></Param>
                                        <Param><![CDATA[the Factored Rank of 'a Agent Decline Ranking']]></Param>
                                    </Expression>
                                </Action>
                            </ActionSet>
                        </Condition>
                    </Partition>
                </Condition>
                <Condition>
                    <Expression>
                        <Param><![CDATA[the Question ID of 'a Agent Abondonment Ranking']]></Param>
                    </Expression>
                    <Partition DefId="C1">
                        <Condition>
                            <Expression>
                                <Text><![CDATA[<a number> is less than <a number>]]></Text>
                                <Param><![CDATA[the Factored Rank of 'a Agent Abondonment Ranking']]></Param>
                            </Expression>
                            <ActionSet>
                                <Action DefId="A0">
                                    <Expression>
                                        <Param><![CDATA[the Question ID of 'a Agent Decline Ranking']]></Param>
                                        <Param><![CDATA[the Factored Rank of 'a Agent Abondonment Ranking']]></Param>
                                    </Expression>
                                </Action>
                            </ActionSet>
                        </Condition>
                    </Partition>
                </Condition>
            </Partition>
        </Contents>
    </Body>
    <Resources DefaultLocale="en_US">
        <ResourceSet Locale="en_US">
            <Data Name="Definitions(C0)#HeaderText"><![CDATA[Question ID ]]></Data>
            <Data Name="Definitions(C1)#HeaderText"><![CDATA[Factored Rank]]></Data>
            <Data Name="Definitions(A0)#Width"><![CDATA[538]]></Data>
            <Data Name="Definitions(A0)#HeaderText"><![CDATA[Question Ranking List]]></Data>
            <Data Name="Definitions(C1)#Width"><![CDATA[241]]></Data>
        </ResourceSet>
    </Resources>
</DT>
</definition>
</ilog.rules.studio.model.dt:DecisionTable>
