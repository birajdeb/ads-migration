<?xml version="1.0" encoding="UTF-8"?>
<ilog.rules.studio.model.dt:DecisionTable xmi:version="2.0" xmlns:xmi="http://www.omg.org/XMI" xmlns:ilog.rules.studio.model.dt="http://ilog.rules.studio/model/dt.ecore">
  <name>Vehicle List</name>
  <uuid>c971ec9d-1982-4937-963e-7b0c73332610</uuid>
  <locale>en_US</locale>
  <definition><DT xmlns="http://schemas.ilog.com/Rules/7.0/DecisionTable" Version="7.0">
    <Body>
        <Properties>
            <Property Name="UI.MediaType"><![CDATA[Web]]></Property>
            <Property Name="UI.RenderBoolean" Type="xs:boolean"><![CDATA[true]]></Property>
        </Properties>
        <Preconditions>
            <Text><![CDATA[definitions
set 'a Question Response' to a Question Response in 'Question Response';
set 'a Car Inventory' to a Car Inventory in 'Car Inventory';]]></Text>
        </Preconditions>
        <Structure>
            <ConditionDefinitions>
                <ConditionDefinition Id="C0">
                    <Properties>
                        <Property Name="Check.Gap" Type="xs:boolean"><![CDATA[false]]></Property>
                        <Property Name="Check.Overlap" Type="xs:boolean"><![CDATA[false]]></Property>
                    </Properties>
                    <ExpressionDefinition>
                        <Text><![CDATA[the Question ID of 'a Question Response' is <a Questions> ]]></Text>
                    </ExpressionDefinition>
                </ConditionDefinition>
                <ConditionDefinition Id="C1">
                    <ExpressionDefinition>
                        <Text><![CDATA[utils.extractNumericValue(the Answer of 'a Question Response' ) is  <a number> ]]></Text>
                    </ExpressionDefinition>
                </ConditionDefinition>
            </ConditionDefinitions>
            <ActionDefinitions>
                <ActionDefinition Id="A0">
                    <ExpressionDefinition>
                        <Text><![CDATA[add a new Vehicle List where
	Applied Indicator is <Applied Indicator> , 
	the Car Price is <Car Price> , 
	the Downpayment Threshold is <Downpayment Threshold> , 
	the Car ID is <Car ID> to decision]]></Text>
                    </ExpressionDefinition>
                </ActionDefinition>
            </ActionDefinitions>
        </Structure>
        <Contents>
            <Partition DefId="C0">
                <Condition>
                    <Expression>
                        <Param><![CDATA[Q5 - Car Price]]></Param>
                    </Expression>
                    <Partition DefId="C1">
                        <Condition>
                            <Expression>
                                <Text><![CDATA[<a number> equals <a number>]]></Text>
                                <Param><![CDATA[the Car Price of 'a Car Inventory']]></Param>
                            </Expression>
                            <ActionSet>
                                <Action DefId="A0">
                                    <Expression>
                                        <Param><![CDATA[true]]></Param>
                                        <Param><![CDATA[the Car Price of 'a Car Inventory']]></Param>
                                        <Param><![CDATA[the Car Price of 'a Car Inventory' * 0.15]]></Param>
                                        <Param><![CDATA[the Car ID of 'a Car Inventory']]></Param>
                                    </Expression>
                                </Action>
                            </ActionSet>
                        </Condition>
                    </Partition>
                </Condition>
                <Condition>
                    <Expression>
                        <Param><![CDATA[Q5 - Car Price]]></Param>
                    </Expression>
                    <Partition DefId="C1">
                        <Condition>
                            <Expression>
                                <Text><![CDATA[<a number> does not equal <a number>]]></Text>
                                <Param><![CDATA[the Car Price of 'a Car Inventory']]></Param>
                            </Expression>
                            <ActionSet>
                                <Action DefId="A0">
                                    <Expression>
                                        <Param><![CDATA[false]]></Param>
                                        <Param><![CDATA[the Car Price of 'a Car Inventory']]></Param>
                                        <Param><![CDATA[the Car Price of 'a Car Inventory' * 0.15]]></Param>
                                        <Param><![CDATA[the Car ID of 'a Car Inventory']]></Param>
                                    </Expression>
                                </Action>
                            </ActionSet>
                        </Condition>
                    </Partition>
                </Condition>
            </Partition>
        </Contents>
    </Body>
    <Resources DefaultLocale="en_US">
        <ResourceSet Locale="en_US">
            <Data Name="Definitions(C0)#HeaderText"><![CDATA[Question ID]]></Data>
            <Data Name="Definitions(C1)#HeaderText"><![CDATA[Answer]]></Data>
            <Data Name="Definitions(A0)#Width"><![CDATA[712]]></Data>
            <Data Name="Definitions(A0)#HeaderText"><![CDATA[Vehical List]]></Data>
        </ResourceSet>
    </Resources>
</DT>
</definition>
</ilog.rules.studio.model.dt:DecisionTable>
