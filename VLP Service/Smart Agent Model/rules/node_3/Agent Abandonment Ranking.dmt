                    </Partition>
                </Condition>
                <Condition>
                    <Expression>
                        <Param><![CDATA[Q3 - Gross Monthly Income]]></Param>
                    </Expression>
                    <Partition DefId="C2">
                        <Condition>
                            <Expression>
                                <Param><![CDATA[Not Answered]]></Param>
                            </Expression>
                            <ActionSet>
                                <Action DefId="A0">
                                    <Expression>
                                        <Param><![CDATA[2]]></Param>
                                        <Param><![CDATA[Q3 - Gross Monthly Income]]></Param>
                                    </Expression>
                                </Action>
                            </ActionSet>
                        </Condition>
                    </Partition>
                </Condition>
                <Condition>
                    <Expression>
                        <Param><![CDATA[Q4 - Expenses]]></Param>
                    </Expression>
                    <Partition DefId="C2">
                        <Condition>
                            <Expression>
                                <Param><![CDATA[Not Answered]]></Param>
                            </Expression>
                            <ActionSet>
                                <Action DefId="A0">
                                    <Expression>
                                        <Param><![CDATA[4]]></Param>
                                        <Param><![CDATA[Q4 - Expenses]]></Param>
