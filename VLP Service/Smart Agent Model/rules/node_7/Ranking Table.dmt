<?xml version="1.0" encoding="UTF-8"?>
<ilog.rules.studio.model.dt:DecisionTable xmi:version="2.0" xmlns:xmi="http://www.omg.org/XMI" xmlns:ilog.rules.studio.model.dt="http://ilog.rules.studio/model/dt.ecore">
  <name>Ranking Table</name>
  <uuid>36ffc804-142d-4196-a84e-a82b2a1cdda5</uuid>
  <locale>en_US</locale>
  <definition><DT xmlns="http://schemas.ilog.com/Rules/7.0/DecisionTable" Version="7.0">
    <Body>
        <Properties>
            <Property Name="UI.MediaType"><![CDATA[Web]]></Property>
            <Property Name="UI.RenderBoolean" Type="xs:boolean"><![CDATA[true]]></Property>
        </Properties>
        <Preconditions>
            <Text><![CDATA[definitions
   set 'matchingQuestion' to a Questions in the questionses of 'Previous Questions' ;
   set 'Agent Abandonment Ranking value' to a Ranking Output in 'Agent Abandonment Ranking' where the  Question of this Ranking Output is matchingQuestion ;
   set 'Agent Decline Ranking value' to a Ranking Output in 'Agent Decline Ranking' ;
   set 'Factor Decline Ranking value' to a number in the A Rankings of 'Factor Decline Ranking' ;
if
   ( the Question of 'Agent Abandonment Ranking value' is the Question of 'Agent Decline Ranking value' )
   and ( the Question of 'Agent Abandonment Ranking value' is 'matchingQuestion' )
   and (the Question of 'Agent Abandonment Ranking value'  is not one of the Questions of decision)]]></Text>
        </Preconditions>
        <Structure>
            <ConditionDefinitions>
                <ConditionDefinition Id="C0">
                    <Properties>
                        <Property Name="Check.Gap" Type="xs:boolean"><![CDATA[false]]></Property>
                        <Property Name="Check.Overlap" Type="xs:boolean"><![CDATA[false]]></Property>
                    </Properties>
                    <ExpressionDefinition>
                        <Text><![CDATA[ matchingQuestion is <a Questions> ]]></Text>
                    </ExpressionDefinition>
                </ConditionDefinition>
                <ConditionDefinition Id="C1">
                    <ExpressionDefinition>
                        <Text><![CDATA['Factor Decline Ranking value' is <an object> ]]></Text>
                    </ExpressionDefinition>
                </ConditionDefinition>
            </ConditionDefinitions>
            <ActionDefinitions>
                <ActionDefinition Id="A0">
                    <ExpressionDefinition>
                        <Text><![CDATA[add a new Ranking Output where
      the Question is <Question> , 
      the A Ranking is <A Ranking> to decision ]]></Text>
                    </ExpressionDefinition>
                </ActionDefinition>
            </ActionDefinitions>
        </Structure>
        <Contents>
            <Partition DefId="C0">
                <Condition>
                    <Expression>
                        <Param><![CDATA[Q1 - Age]]></Param>
                    </Expression>
                    <Partition DefId="C1">
                        <Condition>
                            <Expression>
                                <Text><![CDATA[<a number> is at least <a number>]]></Text>
                                <Param><![CDATA[the A Ranking of 'Agent Abandonment Ranking value']]></Param>
                            </Expression>
                            <ActionSet>
                                <Action DefId="A0">
                                    <Expression>
                                        <Param><![CDATA[the Question of 'Agent Abandonment Ranking value']]></Param>
                                        <Param><![CDATA[max ( the A Ranking of 'Agent Abandonment Ranking value' , the A Ranking of 'Agent Decline Ranking value' )]]></Param>
                                    </Expression>
                                </Action>
                            </ActionSet>
                        </Condition>
                    </Partition>
                </Condition>
