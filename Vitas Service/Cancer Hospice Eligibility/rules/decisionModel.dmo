                <input bomType="ankurmore_bluepolaris.com.vitas.vitas_service.datamodel.Failure$NotFailure" collection="false" name="Failure to Respond to Treatment"/>
                <input bomType="ankurmore_bluepolaris.com.vitas.vitas_service.datamodel.PathologyAggressiveList" collection="true" name="Pathology Aggressive List"/>
