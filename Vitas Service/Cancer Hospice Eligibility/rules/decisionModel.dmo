                <input bomType="ankurmore_bluepolaris.com.vitas.vitas_service.datamodel.HighlyAggressive$NotHighlyAggressive" collection="false" name="Highly Aggressive Indicator"/>
                <input bomType="ankurmore_bluepolaris.com.vitas.vitas_service.datamodel.Failure$NotFailure" collection="false" name="Failure to Respond to Treatment"/>
