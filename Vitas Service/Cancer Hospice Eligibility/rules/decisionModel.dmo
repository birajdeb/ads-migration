    <decision id="node_9" name="ECOG Scale">
        <description>What is the eastern cooperative oncology group (ECOG) performance scale for this patient?</description>
        <extensionElements>
            <ruleset xmlns="http://www.ibm.com/spec/ODM/dmn.xsd" conflictResolution="sequence">
                <input bomType="ankurmore_bluepolaris.com.vitas.vitas_service.datamodel.PreAdmissionEvaluationForm" collection="false" name="Pre Admission Evaluation Form"/>
                <input bomType="ankurmore_bluepolaris.com.vitas.vitas_service.datamodel.AmbulatoryLevel" collection="false" name="Ambulatory Level"/>
                <input bomType="ankurmore_bluepolaris.com.vitas.vitas_service.datamodel.AmbulatoryLevel" collection="false" name="Selfcare Level"/>
                <output bomType="java.lang.Double" collection="false" name="ECOG Scale"/>
                <rule defaultRule="false" href="node_9/ECOG%20Scale.dmt" kind="DecisionTable" name="ECOG Scale"/>
