 set 'policy benefit value' to a string in 'Policy Benefit Level Output' ;
 set 'primary policy information' to a Policy in 'Primary Policy Information' ;
 set 'secondary policy information' to a Policy in 'Secondary Policy Information' ;]]></Text>
