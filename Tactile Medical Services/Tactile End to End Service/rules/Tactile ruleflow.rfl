  <uuid>43924942-94e3-4e30-9e1b-03419ad7bc32</uuid>
  <locale>en_US</locale>
  <rfModel><Ruleflow xmlns="http://schemas.ilog.com/Rules/7.0/Ruleflow">
    <Body>
        <TaskList>
            <StartTask Identifier="task_0"/>
            <StopTask Identifier="task_2"/>
            <FunctionTask Identifier="task_3">
                <FinalActions Language="bal"><![CDATA[set 'the FinalOutput' to a new Final Outputs where 
	the Order Pricing Table Assignments are 'the OrderPricingTableAssignment' ;]]></FinalActions>
                <Invocation FunctionIdentifier="vkokate_bluepolaris.com.tactile_medical.tactile_medical_services.orderpricingtableassignment.Order_Pricing_Table_Assignment">
                    <InputBindings>
                        <Binding Language="bal" Name="network"><![CDATA[ 'the Network' ]]></Binding>
                        <Binding Language="bal" Name="patient"><![CDATA[ 'the Patient' ]]></Binding>
                        <Binding Language="bal" Name="policy"><![CDATA[ 'the Policy' ]]></Binding>
                        <Binding Language="bal" Name="order"><![CDATA[ 'the Order' ]]></Binding>
                        <Binding Language="bal" Name="policyActivity"><![CDATA[ 'the PolicyActivity' ]]></Binding>
                        <Binding Language="bal" Name="payer"><![CDATA[ 'the PayerInsurance' ]]></Binding>
                    </InputBindings>
                    <OutputBindings>
                        <Binding Language="bal" Name="OrderPricingTableAssignment"><![CDATA[ 'order pricing table assignment' ]]></Binding>
                    </OutputBindings>
                </Invocation>
            </FunctionTask>
            <FunctionTask Identifier="task_4">
                <FinalActions Language="bal"><![CDATA[set the Policy Months Remaining of 'the FinalOutput' to 'the PolicyMonthsRemaining' ; ]]></FinalActions>
