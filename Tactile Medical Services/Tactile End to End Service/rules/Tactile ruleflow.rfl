                        <Binding Language="bal" Name="payer"><![CDATA[ 'the PayerInsurance' ]]></Binding>
                        <Binding Language="bal" Name="state"><![CDATA[ 'the State' ]]></Binding>
                    </InputBindings>
                    <OutputBindings>
                        <Binding Language="bal" Name="CalculateAllowables"><![CDATA[ 'calculate allowables' ]]></Binding>
                    </OutputBindings>
                </Invocation>
            </FunctionTask>
            <FunctionTask Identifier="task_6">
