                    </InputBindings>
                    <OutputBindings>
                        <Binding Language="bal" Name="PolicyMonthsRemaining"><![CDATA[ 'policy months remaining' ]]></Binding>
                    </OutputBindings>
                </Invocation>
            </FunctionTask>
            <FunctionTask Identifier="task_5">
                <FinalActions Language="bal"><![CDATA[set the Calculate Allowables of 'the FinalOutput' to 'the CalculateAllowables' ; ]]></FinalActions>
                <Invocation FunctionIdentifier="ankurmore_bluepolaris.com.medical.tactile_medical_services.calculateallowables.Calculate_Allowables">
                    <InputBindings>
