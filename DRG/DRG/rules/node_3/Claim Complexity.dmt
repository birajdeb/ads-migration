<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<ilog.rules.studio.model.dt:DecisionTable xmlns:ilog.rules.studio.model.dt="http://ilog.rules.studio/model/dt.ecore" xmlns:xmi="http://www.omg.org/XMI" xmi:version="2.0">
    <name>Claim Complexity</name>
    <uuid>89135e8b-e4f6-4e96-b721-b7550d78ce7d</uuid>
    <locale>en_US</locale>
    <definition>
        <DT Version="7.0" xmlns="http://schemas.ilog.com/Rules/7.0/DecisionTable">
            <Body>
                <Properties>
                    <Property Name="UI.MediaType"><![CDATA[Web]]></Property>
                    <Property Name="UI.RenderBoolean" Type="xs:boolean"><![CDATA[true]]></Property>
                </Properties>
                <Structure>
                    <ConditionDefinitions>
                        <ConditionDefinition Id="C0">
                            <Properties>
                                <Property Name="Check.Overlap" Type="xs:boolean"><![CDATA[false]]></Property>
                                <Property Name="Check.Gap" Type="xs:boolean"><![CDATA[false]]></Property>
                            </Properties>
                            <ExpressionDefinition>
                                <Text><![CDATA['Diagnosis Complexity' is <a string>]]></Text>
                            </ExpressionDefinition>
                        </ConditionDefinition>
                        <ConditionDefinition Id="C1">
                            <Properties>
                                <Property Name="Check.Overlap" Type="xs:boolean"><![CDATA[false]]></Property>
                                <Property Name="Check.Gap" Type="xs:boolean"><![CDATA[false]]></Property>
                            </Properties>
                            <ExpressionDefinition>
                                <Text><![CDATA['Treatment Complexity' is <a string>]]></Text>
                            </ExpressionDefinition>
                        </ConditionDefinition>
                        <ConditionDefinition Id="C2">
                            <Properties>
                                <Property Name="Check.Overlap" Type="xs:boolean"><![CDATA[false]]></Property>
                                <Property Name="Check.Gap" Type="xs:boolean"><![CDATA[false]]></Property>
                            </Properties>
                            <ExpressionDefinition>
                                <Text><![CDATA['Claim History Complexity' is <a string>]]></Text>
                            </ExpressionDefinition>
                        </ConditionDefinition>
                    </ConditionDefinitions>
                    <ActionDefinitions>
                        <ActionDefinition Id="A0">
                            <ExpressionDefinition>
                                <Text><![CDATA[set 'decision' to <a string>]]></Text>
                            </ExpressionDefinition>
                        </ActionDefinition>
                    </ActionDefinitions>
                </Structure>
                <Contents>
                    <Partition DefId="C0">
                        <Condition>
                            <Expression>
                                <Param><![CDATA["Low"]]></Param>
                            </Expression>
                            <Partition DefId="C1">
                                <Condition>
                                    <Expression>
                                        <Param><![CDATA["Low"]]></Param>
                                    </Expression>
                                    <Partition DefId="C2">
                                        <Condition>
