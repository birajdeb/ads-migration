                                </Condition>
                            </Partition>
                        </Condition>
                        <Condition>
                            <Expression>
                                <Text><![CDATA[<a string> is not <a string>]]></Text>
                                <Param><![CDATA["High"]]></Param>
                            </Expression>
                            <Partition DefId="C1">
                                <Condition>
                                    <Expression>
                                        <Param><![CDATA["Moderate"]]></Param>
                                    </Expression>
                                    <Partition DefId="C2">
                                        <Condition>
                                            <Expression>
                                                <Text><![CDATA[<a string> is not <a string>]]></Text>
                                                <Param><![CDATA["High"]]></Param>
                                            </Expression>
                                            <ActionSet>
